# teleshell - Environment Variables
# Copy this file to .env, then fill in the values

# Token from @BotFather
BOT_TOKEN=your_token_here

# User IDs allowed to access the bot
# Multiple IDs can be separated with commas
# Find your ID with @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321

# The legacy name is still supported for compatibility:
# ALLOWED_CHAT_IDS=123456789,987654321

# Telegram API timeouts in seconds
# Increase these if the Telegram connection often times out.
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=10
TELEGRAM_MEDIA_WRITE_TIMEOUT=120
TELEGRAM_GET_UPDATES_READ_TIMEOUT=60
POLLING_TIMEOUT=30
