# teleshell - Environment Variables
# Copy this file to .env, then fill in the values

# Token from @BotFather
BOT_TOKEN=your_token_here

# User IDs allowed to access the bot
# Multiple IDs can be separated with commas
# Find your ID with @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321

# The legacy name is still supported for compatibility:
# ALLOWED_CHAT_IDS=123456789,987654321

# Telegram API timeouts in seconds
# Increase these if the Telegram connection often times out.
LOG_LEVEL=WARNING
HTTP_LOG_LEVEL=WARNING
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=10
TELEGRAM_MEDIA_WRITE_TIMEOUT=120
TELEGRAM_GET_UPDATES_READ_TIMEOUT=60
POLLING_TIMEOUT=30

# Safer command routing. When true, shell commands must use /run <command>.
SAFE_MODE=true

# Background autorun through a systemd user service
AUTORUN=false
SERVICE_NAME=teleshell

# Extra command directories prepended to PATH for shell, /pty, and services.
# Common user bins such as ~/.opencode/bin and ~/.local/bin are added automatically.
COMMAND_EXTRA_PATHS=

# Claude chat bridge settings
CLAUDE_BRIDGE_COMMAND=claude
CLAUDE_BRIDGE_ARGS=--print --permission-mode acceptEdits
CLAUDE_BRIDGE_TIMEOUT=300

# Commands that should automatically open an interactive pseudo-terminal session
INTERACTIVE_COMMANDS=python,python3,node,ssh,mysql,psql
