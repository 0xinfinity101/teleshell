# Telegram Terminal Bot — Environment Variables
# Salin file ini jadi .env lalu isi nilainya

# Token dari @BotFather
BOT_TOKEN=isi_token_kamu_disini

# User ID yang diizinkan akses bot
# Bisa lebih dari satu, pisah dengan koma
# Cari ID kamu via @userinfobot di Telegram
ALLOWED_USER_IDS=123456789,987654321

# Nama lama masih didukung untuk kompatibilitas:
# ALLOWED_CHAT_IDS=123456789,987654321

# Timeout Telegram API dalam detik
# Naikkan jika koneksi ke Telegram sering timeout.
TELEGRAM_CONNECT_TIMEOUT=15
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=10
TELEGRAM_MEDIA_WRITE_TIMEOUT=120
TELEGRAM_GET_UPDATES_READ_TIMEOUT=60
POLLING_TIMEOUT=30
